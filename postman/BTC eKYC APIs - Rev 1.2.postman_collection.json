      "item": [
        {
          "name": "2. Subscriber Retrieve",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "text/xml;charset=UTF-8"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<soapenv:Envelope xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\" xmlns:com=\"http://www.comverse.com\">\n   <soapenv:Header/>\n   <soapenv:Body>\n      <com:SubscriberRetrieve>\n         <com:input>\n            <realm>{{c1_realm}}</realm>\n            <securityToken>{{security_token}}</securityToken>\n            <userIdName>{{c1_username}}</userIdName>\n            <subscriberId>\n               <subscriberId>\n                  <value>{{msisdn}}</value>\n               </subscriberId>\n               <subscriberExternalIdType>\n                  <value>1</value>\n               </subscriberExternalIdType>\n            </subscriberId>\n            <info>\n               <attribs>1</attribs>\n               <useBillingDB changed=\"true\" set=\"true\">\n                  <value>true</value>\n               </useBillingDB>\n               <subscriberData changed=\"true\" set=\"true\">\n                  <value>true</value>\n               </subscriberData>\n               <balances changed=\"true\" set=\"true\">\n                  <value>1</value>\n               </balances>\n               <externalIds changed=\"true\" set=\"true\">\n                  <value>true</value>\n               </externalIds>\n               <offers changed=\"true\" set=\"true\">\n                  <value>true</value>\n               </offers>\n            </info>\n         </com:input>\n      </com:SubscriberRetrieve>\n   </soapenv:Body>\n</soapenv:Envelope>",
              "options": {
                "raw": {
                  "language": "xml"
                }
              }
            },
            "url": {
              "raw": "http://{{c1_billing_host}}/services/SubscriberService",
              "protocol": "http",
              "host": [
                "{{c1_billing_host}}"
              ],
              "path": [
                "services",
                "SubscriberService"
              ]
            },
            "description": "Check if MSISDN exists and retrieve subscriber info including serviceInternalId"
          },
          "response": []
        },
        {
          "name": "3. Subscriber Resume",
