                "key": "x-api-key",
                "value": "{{bocra_api_key}}"
              }
            ],
            "url": {
              "raw": "https://{{bocra_host}}/api/v1/phone_numbers/msisdn/{{msisdn}}",
              "protocol": "https",
              "host": [
                "{{bocra_host}}"
              ],
              "path": [
                "api",
                "v1",
                "phone_numbers",
                "msisdn",
                "{{msisdn}}"
              ]
            },
            "description": "Check if subscriber is registered at BOCRA by phone number"
          },
          "response": []
        },
