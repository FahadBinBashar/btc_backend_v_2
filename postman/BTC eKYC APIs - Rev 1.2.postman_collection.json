          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{bocra_api_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{bocra_subscriber_id}}\",\n  \"Documents\": [\n    {\n      \"documentNumber\": \"{{document_number}}\",\n      \"documentType\": \"NATIONAL_ID\",\n      \"dateOfIssue\": \"{{document_issue_date}}\",\n      \"expiryDate\": \"{{document_expiry_date}}\"\n    }\n  ],\n  \"addresses\": [\n    {\n      \"plotWardBox\": \"{{address}}\",\n      \"cityTown\": \"{{city}}\",\n      \"addressType\": \"POSTAL\"\n    }\n  ]\n}",
              "options": {
