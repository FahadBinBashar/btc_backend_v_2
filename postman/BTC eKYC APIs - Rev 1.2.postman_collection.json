                "value": "text/xml;charset=UTF-8"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<soapenv:Envelope xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\" xmlns:com=\"http://www.converse.com\">\n   <soapenv:Header/>\n   <soapenv:Body>\n      <com:SubscriberResumeBilling>\n         <com:input>\n            <realm>{{c1_realm}}</realm>\n            <securityToken>{{security_token}}</securityToken>\n            <userIdName>{{c1_username}}</userIdName>\n            <subscriberId>\n               <serviceInternalId set=\"true\" changed=\"true\">\n                  <value>{{service_internal_id}}</value>\n               </serviceInternalId>\n               <serviceInternalIdResets set=\"true\" changed=\"true\">\n                  <value>0</value>\n               </serviceInternalIdResets>\n            </subscriberId>\n            <statusReasonId>13</statusReasonId>\n            <comment>KYC compliant</comment>\n            <autoCommitOrder>1</autoCommitOrder>\n            <generateWorkflow>true</generateWorkflow>\n         </com:input>\n      </com:SubscriberResumeBilling>\n   </soapenv:Body>\n</soapenv:Envelope>",
              "options": {
                "raw": {
                  "language": "xml"
                }
              }
            },
            "url": {
              "raw": "http://{{c1_billing_host}}/services/SubscriberService",
              "protocol": "http",
              "host": [
                "{{c1_billing_host}}"
              ],
              "path": [
                "services",
                "SubscriberService"
              ]
            },
            "description": "Resume suspended service (statusReasonId: 13 = KYC compliant)"
          },
          "response": []
        },
