            ],
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<soapenv:Envelope xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\" xmlns:auth=\"https://org.converse.rtbd.sec/webservice/auth\">\n   <soapenv:Header/>\n   <soapenv:Body>\n      <auth:proxyLogin>\n         <String_1>{{c1_username}}</String_1>\n         <String_2>{{c1_password}}</String_2>\n         <String_3>{{c1_realm}}</String_3>\n      </auth:proxyLogin>\n   </soapenv:Body>\n</soapenv:Envelope>",
              "options": {
                "raw": {
                  "language": "xml"
                }
              }
            },
            "url": {
              "raw": "https://{{c1_host}}/SAMLSignOnWS?wsdl",
              "protocol": "https",
              "host": [
                "{{c1_host}}"
              ],
              "path": [
                "SAMLSignOnWS"
              ],
              "query": [
                {
                  "key": "wsdl",
                  "value": null
                }
              ]
            },
            "description": "Authenticate and retrieve SecurityToken for C1 API access"
          },
          "response": []
        }
      ]
