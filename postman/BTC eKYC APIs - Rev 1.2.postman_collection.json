        {
          "name": "12. Register at BOCRA",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{bocra_api_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"msisdn\": \"{{msisdn}}\",\n  \"firstName\": \"{{first_name}}\",\n  \"lastName\": \"{{last_name}}\",\n  \"country\": \"BOTSWANA\",\n  \"dateOfBirth\": \"{{dob_iso}}\",\n  \"sex\": \"{{gender}}\",\n  \"documents\": [\n    {\n      \"documentNumber\": \"{{document_number}}\",\n      \"documentType\": \"{{document_type}}\",\n      \"dateOfIssue\": \"{{document_issue_date}}\",\n      \"expiryDate\": \"{{document_expiry_date}}\"\n    }\n  ],\n  \"addresses\": [\n    {\n      \"plotWardBox\": \"{{physical_address}}\",\n      \"cityTown\": \"{{city}}\",\n      \"addressType\": \"PHYSICAL\"\n    },\n    {\n      \"plotWardBox\": \"{{postal_address}}\",\n      \"cityTown\": \"{{city}}\",\n      \"addressType\": \"POSTAL\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
