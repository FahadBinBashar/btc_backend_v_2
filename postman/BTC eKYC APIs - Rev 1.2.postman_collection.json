            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "text/xml;charset=UTF-8"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<soapenv:Envelope xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\" xmlns:com=\"http://www.converse.com\">\n   <soapenv:Header/>\n   <soapenv:Body>\n      <com:SubscriberUpdate>\n         <com:input>\n            <realm>{{c1_realm}}</realm>\n            <securityToken>{{security_token}}</securityToken>\n            <userIdName>{{c1_username}}</userIdName>\n            <subscriber>\n               <attribs>0</attribs>\n               <serviceInternalId changed=\"true\" set=\"true\">\n                  <value>{{service_internal_id}}</value>\n               </serviceInternalId>\n               <serviceInternalIdResets changed=\"true\" set=\"true\">\n                  <value>0</value>\n               </serviceInternalIdResets>\n               <serviceCompany changed=\"true\" set=\"true\">\n                  <value>BTC</value>\n               </serviceCompany>\n               <serviceFname changed=\"true\" set=\"true\">\n                  <value>{{first_name}}</value>\n               </serviceFname>\n               <serviceLname changed=\"true\" set=\"true\">\n                  <value>{{last_name}}</value>\n               </serviceLname>\n               <servicePhone changed=\"true\" set=\"true\">\n                  <value>{{msisdn}}</value>\n               </servicePhone>\n               <servicePhone2 changed=\"true\" set=\"true\">\n                  <value>{{alt_phone}}</value>\n               </servicePhone2>\n               <streetName changed=\"true\" set=\"true\">\n                  <value>{{street}}</value>\n               </streetName>\n               <extendedData changed=\"false\" set=\"true\">\n                  <value>ExtendedData XML here</value>\n               </extendedData>\n            </subscriber>\n            <personas>\n               <attribs>0</attribs>\n               <person>\n                  <attribs>0</attribs>\n                  <addressline1 changed=\"true\" set=\"true\">\n                     <value>{{address_line1}}</value>\n                  </addressline1>\n                  <city changed=\"true\" set=\"true\">\n                     <value>{{city}}</value>\n                  </city>\n                  <dateOfBirth changed=\"true\" set=\"true\">\n                     <value>{{dob}}</value>\n                  </dateOfBirth>\n                  <email changed=\"true\" set=\"true\">\n                     <value>{{email}}</value>\n                  </email>\n                  <firstName changed=\"true\" set=\"true\">\n                     <value>{{first_name}}</value>\n                  </firstName>\n                  <gender changed=\"true\" set=\"true\">\n                     <value>{{gender}}</value>\n                  </gender>\n                  <lastName changed=\"true\" set=\"true\">\n                     <value>{{last_name}}</value>\n                  </lastName>\n                  <mobile changed=\"true\" set=\"true\">\n                     <value>{{mobile}}</value>\n                  </mobile>\n                  <nationalId changed=\"true\" set=\"true\">\n                     <value>{{national_id}}</value>\n                  </nationalId>\n                  <nationality changed=\"true\" set=\"true\">\n                     <value>{{nationality}}</value>\n                  </nationality>\n                  <phone changed=\"true\" set=\"true\">\n                     <value>{{phone}}</value>\n                  </phone>\n               </person>\n            </personas>\n            <autoCommitOrder>1</autoCommitOrder>\n         </com:input>\n      </com:SubscriberUpdate>\n   </soapenv:Body>\n</soapenv:Envelope>",
              "options": {
                "raw": {
                  "language": "xml"
                }
              }
            },
            "url": {
              "raw": "http://{{c1_billing_host}}/services/SubscriberService",
              "protocol": "http",
              "host": [
                "{{c1_billing_host}}"
              ],
              "path": [
                "services",
                "SubscriberService"
              ]
            },
            "description": "Update subscriber details in billing platform"
          },
          "response": []
