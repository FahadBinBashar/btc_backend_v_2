                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "https://{{bocra_host}}/api/v1/natural_subscribers/update_address_documents",
              "protocol": "https",
              "host": [
                "{{bocra_host}}"
              ],
              "path": [
